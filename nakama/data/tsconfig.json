{
  "compilerOptions": {
    "target": "ES5",
    "module": "ES2015",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "typeRoots": [
      "./node_modules"
    ]
  },
  "include": [
    "main.ts",
    "rpc/**/*.ts",
    "hooks/**/*.ts",
    "nakama-runtime.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
